# apps/web 환경변수 예시.
# 실제 값은 .env.local 에 저장 (.gitignored).

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ── Upstash Redis (Rate Limiting) ─────────────────────────
# 미설정 시 rate limit 비활성 (dev 편의)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Cloudflare R2 (이미지/파일 스토리지) ──────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=gwangjang
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ── PortOne (결제 PG) ────────────────────────────────────
PORTONE_API_KEY=your-portone-api-key
PORTONE_API_SECRET=your-portone-api-secret
PORTONE_MERCHANT_ID=your-merchant-id
PORTONE_CHANNEL_KEY=your-channel-key
NEXT_PUBLIC_PORTONE_STORE_ID=your-store-id

# ── Kakao (지도/지오코딩) ────────────────────────────────
KAKAO_REST_API_KEY=your-kakao-rest-key
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-js-key

# ── Naver (지도/API) ────────────────────────────────────
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=your-naver-client-id
NAVER_MAP_CLIENT_SECRET=your-naver-client-secret

# ── Sentry (에러 모니터링, 선택) ─────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ── 사이트 설정 ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.gwangjang.app
