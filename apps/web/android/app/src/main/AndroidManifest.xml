<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:replace="android:usesCleartextTraffic,android:networkSecurityConfig">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTop"
            android:exported="true">

            <!-- 앱 런처 진입 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: app.gwangjang://property/abc123 같은 custom scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="@string/custom_url_scheme" />
            </intent-filter>

            <!-- App Link (https://gwangjang.app/*) 는 자기 호출 loop 위험 있어 제거.
                 launchMode=singleTask + autoVerify=false 조합에서 WebView 가 라이브 URL 로드 시
                 안드로이드가 "이 URL 광장 앱이 열어야" 인식 → 자기 자신 재launch → 무한 loop → 크래시.
                 추후 assetlinks.json 호스팅 + autoVerify=true 검증 후 재추가 검토. -->
            <!--
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="gwangjang.app" />
                <data android:host="*.gwangjang.app" />
            </intent-filter>
            -->

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- ============================================================
         Permissions
         ============================================================ -->

    <!-- 네트워크 통신 (필수, 모든 API 호출) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 네트워크 상태 감지 (lib/native/network.ts → @capacitor/network) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 카메라 — 매물 / 모임 사진 촬영 (lib/native/camera.ts → @capacitor/camera) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- 위치 — 정확한 / 대략적 위치 (내 주변 매물 / 광장 자동 선택) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 푸시 알림 — Android 13 (API 33) 이상 런타임 권한 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 갤러리 (이미지 / 동영상) — Android 13 (API 33) 이상 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!-- 갤러리 fallback — Android 12 (API 32) 이하만 (그 이상은 READ_MEDIA_* 사용) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- 이미지 저장 — Android 9 (API 28) 이하만. 이상은 scoped storage 자동 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- 햅틱 (진동) — lib/native/haptics.ts. Capacitor 가 보통 자동 추가하지만 명시 -->
    <uses-permission android:name="android.permission.VIBRATE" />

</manifest>
