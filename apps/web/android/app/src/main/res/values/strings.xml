<?xml version='1.0' encoding='utf-8'?>
<resources>
    <!-- 앱 메타 -->
    <string name="app_name">광장</string>
    <string name="title_activity_main">광장</string>
    <string name="package_name">app.gwangjang</string>
    <string name="custom_url_scheme">app.gwangjang</string>

    <!-- ============================================================
         권한 요청 다이얼로그 메시지
         (앱 안에서 권한 요청 전 사용자 친화 안내 — pre-prompt rationale)
         WebView/JS 측에서 fetch 또는 Capacitor plugin 호출 전에
         이 메시지를 모달로 보여주면 권한 수락률 크게 향상.
         ============================================================ -->

    <!-- 카메라 -->
    <string name="permission_camera_title">카메라 권한이 필요해요</string>
    <string name="permission_camera_message">매물 사진이나 모임 인증샷을 직접 찍으려면 카메라 사용 권한이 필요합니다.</string>
    <string name="permission_camera_denied">카메라 권한이 거절되었어요. 설정에서 변경할 수 있어요.</string>

    <!-- 위치 -->
    <string name="permission_location_title">위치 정보 사용</string>
    <string name="permission_location_message">내 동네 광장을 자동으로 선택하고 주변 매물을 보여드리려면 위치 권한이 필요합니다.</string>
    <string name="permission_location_denied">위치 권한이 없어 광장을 직접 선택해야 해요.</string>

    <!-- 갤러리 / 사진 -->
    <string name="permission_photos_title">갤러리 접근 권한</string>
    <string name="permission_photos_message">매물 사진이나 프로필 이미지를 갤러리에서 선택하려면 권한이 필요해요.</string>
    <string name="permission_photos_denied">갤러리 권한이 없어 사진을 첨부할 수 없어요.</string>

    <!-- 푸시 알림 (Android 13+) -->
    <string name="permission_notifications_title">알림 받기</string>
    <string name="permission_notifications_message">새 댓글, 채팅, 모임 일정, 거래 진행 상황을 실시간으로 알려드려요.</string>
    <string name="permission_notifications_denied">알림 권한이 없어 새 소식을 놓칠 수 있어요.</string>

    <!-- 일반 -->
    <string name="permission_open_settings">설정 열기</string>
    <string name="permission_cancel">나중에</string>
    <string name="permission_grant">허용</string>
</resources>
