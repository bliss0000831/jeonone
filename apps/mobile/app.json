{
  "expo": {
    "name": "전원일기",
    "slug": "jeonwondiary",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jeonwondiary",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "androidStatusBar": {
      "barStyle": "dark-content"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.jeonwondiary.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "현재 위치를 기반으로 동네를 자동 설정하기 위해 사용됩니다.",
        "LSApplicationQueriesSchemes": [
          "nmap",
          "kakaomap",
          "nmap",
          "kakaomap"
        ]
      }
    },
    "android": {
      "package": "app.jeonwondiary.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fae2aa"
      },
      "backgroundColor": "#ffffff",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-blank.png",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "현재 위치를 기반으로 동네를 자동 설정하기 위해 사용됩니다."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://repository.map.naver.com/archive/maven"
            ]
          }
        }
      ],
      [
        "@mj-studio/react-native-naver-map",
        {
          "client_id": "$EXPO_PUBLIC_NAVER_MAP_CLIENT_ID",
          "android": {
            "ACCESS_FINE_LOCATION": true,
            "ACCESS_COARSE_LOCATION": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "578779ed-4583-4580-af31-80a36aba9457"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/578779ed-4583-4580-af31-80a36aba9457"
    }
  }
}
