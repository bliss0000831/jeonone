# apps/mobile 환경변수 예시.
# 실제 .env 파일은 .gitignored — 광장 web 의 .env.local 과 동일 값 복사.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# 광장 API base URL (default: https://www.gwangjang.app).
# 로컬 dev 시 http://10.0.2.2:3000 (Android 에뮬) 로 변경 가능.
# EXPO_PUBLIC_GWANGJANG_API_BASE=https://www.gwangjang.app
