{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Dev (maintenance)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true,
      "env": { "MAINTENANCE_MODE": "true" }
    },
    {
      "name": "Next.js Production",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "start"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "mobile", "exec", "expo", "start", "--web", "--port", "8081"],
      "port": 8081,
      "autoPort": true
    }
  ]
}
